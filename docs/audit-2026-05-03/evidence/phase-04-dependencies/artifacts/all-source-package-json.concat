{
  "name": "@loop/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env --import ./src/instrument.ts src/index.ts",
    "build": "tsup",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "LOOP_E2E_DB=1 vitest run --config=vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "check:ledger": "tsx src/scripts/check-ledger-invariant.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "8.5.0",
    "@bufbuild/protobuf": "2.11.0",
    "@hono/node-server": "2.0.0",
    "@loop/shared": "*",
    "@sentry/hono": "10.51.0",
    "@sentry/node": "10.51.0",
    "@stellar/stellar-sdk": "15.0.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.16",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "sharp": "0.34.5",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.68.2",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
{
  "name": "@loop/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev --host",
    "build": "react-router build",
    "build:mobile": "BUILD_TARGET=mobile react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "10.0.0",
    "@aparajita/capacitor-secure-storage": "8.0.0",
    "@bufbuild/protobuf": "2.11.0",
    "@capacitor/app": "8.1.0",
    "@capacitor/clipboard": "8.0.1",
    "@capacitor/core": "8.3.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/network": "8.0.1",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/push-notifications": "8.0.3",
    "@capacitor/share": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@capgo/inappbrowser": "8.6.1",
    "@loop/shared": "*",
    "@react-router/node": "7.14.2",
    "@react-router/serve": "7.14.2",
    "@sentry/react": "10.51.0",
    "@tanstack/react-query": "5.99.0",
    "isbot": "5.1.39",
    "leaflet": "1.9.4",
    "qrcode": "1.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.2",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@react-router/dev": "7.14.2",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/react": "16.3.2",
    "@types/leaflet": "1.9.21",
    "@types/node": "25.6.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@vitest/coverage-v8": "4.1.4",
    "jsbarcode": "3.12.3",
    "jsdom": "29.1.1",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
{
  "name": "@loop/mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "sync": "cap sync && ./scripts/apply-native-overlays.sh",
    "open:ios": "cap open ios",
    "open:android": "cap open android"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "10.0.0",
    "@aparajita/capacitor-secure-storage": "8.0.0",
    "@capacitor/android": "8.3.1",
    "@capacitor/app": "8.1.0",
    "@capacitor/cli": "8.3.1",
    "@capacitor/clipboard": "8.0.1",
    "@capacitor/core": "8.3.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.3.1",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/network": "8.0.1",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/push-notifications": "8.0.3",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@capgo/inappbrowser": "8.6.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
{
  "name": "@loop/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./src/proto/*": "./src/proto/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
{
  "name": "loop-app",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,backend -c cyan,green \"npm run dev:web\" \"npm run dev:backend\"",
    "dev:web": "npm run dev -w @loop/web",
    "dev:backend": "npm run dev -w @loop/backend",
    "mobile:sync": "npm run sync -w @loop/mobile",
    "typecheck": "npm run typecheck -w @loop/backend -w @loop/web -w @loop/shared",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test -w @loop/backend -w @loop/web",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:e2e": "playwright test --config=playwright.mocked.config.ts",
    "test:e2e:mocked": "playwright test --config=playwright.mocked.config.ts",
    "test:e2e:flywheel": "playwright test --config=playwright.flywheel.config.ts",
    "test:e2e:real": "playwright test",
    "verify": "./scripts/verify.sh",
    "lint:docs": "./scripts/lint-docs.sh",
    "check:bundle-budget": "./scripts/check-bundle-budget.sh",
    "audit": "node ./scripts/check-audit-policy.mjs",
    "build": "npm run build -w @loop/backend -w @loop/web",
    "proto:generate": "cd apps/backend && npx buf generate && cd ../.. && prettier --write 'packages/shared/src/proto/**/*.ts'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@stellar/stellar-sdk": {
      "axios": "1.15.0"
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "2.1.114",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@playwright/test": "1.59.1",
    "@sentry/cli": "2.49.0",
    "@stellar/stellar-sdk": "15.0.1",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "concurrently": "9.2.1",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "wait-on": "9.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
