{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "The Prometheus instance scraping docs/observability/prometheus.yml",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" }
  ],
  "id": null,
  "uid": "loop-backend-slo",
  "title": "Loop backend — SLO dashboard (B-5)",
  "description": "Panels map directly to docs/slo.md's Availability / Latency / Freshness sections plus the worker + circuit-breaker + rate-limit gauges exposed by GET /metrics (apps/backend/src/observability-handlers.ts). Settlement-lag and on-chain-drift SLOs are NOT panelled here — those numbers live behind DB-backed admin endpoints (admin/settlement-lag.ts, admin/asset-drift-state.ts), not the in-memory /metrics scrape; see docs/observability.md for why.",
  "tags": ["loop", "slo", "backend", "b-5"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Availability — docs/slo.md §Availability",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "5xx error rate by route (target: /api/* < 0.5% / 30d, /api/public/* < 0.1% / 30d)",
      "description": "sum(rate(loop_requests_total{status=~\"5..\"}[5m])) by (route) / sum(rate(loop_requests_total[5m])) by (route). docs/slo.md's Availability targets are 30d-windowed; this panel uses a 5m rate for real-time viewing — pair with a longer-range dashboard view (top-right time picker) to eyeball the 30d budget burn.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(loop_requests_total{status=~\"5..\"}[5m])) by (route) / sum(rate(loop_requests_total[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Latency — docs/slo.md §Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 request duration by route (targets: /api/merchants ≤200ms, /api/orders create ≤1500ms, /api/admin/treasury ≤800ms)",
      "description": "histogram_quantile(0.95, sum by (le, route) (rate(loop_request_duration_seconds_bucket[5m])))",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(loop_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{route}} p95"
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Freshness — docs/slo.md §Freshness",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Catalog staleness (1=stale, target: always 0)",
      "description": "loop_catalog_stale{catalog=\"merchants\"|\"locations\"} — 1 means the catalog age exceeded 2x its refresh interval per docs/slo.md.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "loop_catalog_stale",
          "legendFormat": "{{catalog}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Catalog age (merchants ≤12h, locations ≤48h)",
      "description": "time() - loop_catalog_loaded_timestamp_ms{catalog=...} / 1000",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 19 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "time() - loop_catalog_loaded_timestamp_ms / 1000",
          "legendFormat": "{{catalog}} age"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "GeoLite2 DB staleness (go-live-plan §T1-F; false when unconfigured, not just when fresh)",
      "description": "loop_geo_db_stale (1=stale) + loop_geo_db_build_age_days (only emitted when a .mmdb is loaded).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "loop_geo_db_stale",
          "legendFormat": "geo_db_stale"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "loop_geo_db_build_age_days",
          "legendFormat": "build_age_days"
        }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "Worker health (S4-8 wedged-fleet signal)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "type": "table",
      "title": "Worker running / degraded / stale",
      "description": "loop_worker_running / loop_worker_degraded / loop_worker_stale, one row per worker (asset_drift_watcher, payout_worker, procurement_worker, etc — see RuntimeWorkerName in runtime-health.ts).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "loop_worker_running",
          "format": "table",
          "instant": true,
          "legendFormat": "running"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "loop_worker_degraded",
          "format": "table",
          "instant": true,
          "legendFormat": "degraded"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "loop_worker_stale",
          "format": "table",
          "instant": true,
          "legendFormat": "stale"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Worker liveness vs lead-tick age (a healthy-but-never-leading fleet is wedged even though liveness looks fresh)",
      "description": "time() - loop_worker_last_success_timestamp_ms/1000 (this machine is alive) vs time() - loop_worker_last_lead_tick_timestamp_ms/1000 (this machine actually did the work / won the fleet lock). See runtime-health.ts's markWorkerTickSkippedLocked doc comment for why the two can diverge on a healthy fleet.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "time() - loop_worker_last_success_timestamp_ms / 1000",
          "legendFormat": "{{worker}} liveness age"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "time() - loop_worker_last_lead_tick_timestamp_ms / 1000",
          "legendFormat": "{{worker}} lead-tick age"
        }
      ]
    },
    {
      "id": 104,
      "type": "row",
      "title": "Infra — circuit breakers, rate limiting, OTP delivery",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Circuit breaker state per upstream endpoint (0=closed, 1=half_open, 2=open)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 35 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "loop_circuit_state",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Rate-limit 429 rate + fleet-size estimate (S4-4)",
      "description": "rate(loop_rate_limit_hits_total[5m]) paired with loop_rate_limit_fleet_estimate — the divisor rate-limit.ts uses to convert a per-machine budget to a fleet-wide one. A2-1918's quarterly rate-limit review pulls this panel.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 35 },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(loop_rate_limit_hits_total[5m])",
          "legendFormat": "429/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "loop_rate_limit_fleet_estimate",
          "legendFormat": "fleet estimate ({{source}})"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "OTP delivery degraded",
      "description": "loop_runtime_surface_degraded{surface=\"otp_delivery\"} — 1 means the last OTP send failed and no send has since succeeded.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 35 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "loop_runtime_surface_degraded{surface=\"otp_delivery\"}",
          "legendFormat": "otp_delivery"
        }
      ]
    }
  ]
}
