+      txHash: 'never-landed-hash',
+      oldestLedger: 50,
+      latestLedger: 800,
+    });
+
+    const result = await submitSorobanInvocation({
+      ...baseArgs,
+      priorTxHash: 'never-landed-hash',
+      priorTxSubmittedLedger: 100,
+    });
+
+    expect(result.deduped).toBe(false);
+    expect(rpcState.calls.sendTransaction).toHaveLength(1);
+  });
+
+  it('treats oldestLedger === submittedLedger as still-covered (boundary) — retries, does not fail closed', async () => {
+    rpcState.simulateResult = successSim(xdr.ScVal.scvVoid());
+    rpcState.pollResult = successTx('fresh-hash', xdr.ScVal.scvVoid());
+    rpcState.getTransactionResults.set('boundary-hash', {
+      status: rpc.Api.GetTransactionStatus.NOT_FOUND,
+      txHash: 'boundary-hash',
+      oldestLedger: 100,
+      latestLedger: 800,
+    });
+
+    const result = await submitSorobanInvocation({
+      ...baseArgs,
+      priorTxHash: 'boundary-hash',
+      priorTxSubmittedLedger: 100,
+    });
+
+    expect(result.deduped).toBe(false);
+    expect(rpcState.calls.sendTransaction).toHaveLength(1);
+  });
+
+  it('a landed SUCCESS still dedups even with a submit ledger supplied (the retention check is NOT_FOUND-only)', async () => {
+    rpcState.getTransactionResults.set(
+      'landed-hash',
+      successTx('landed-hash', xdr.ScVal.scvVoid()),
+    );
+
+    const result = await submitSorobanInvocation({
+      ...baseArgs,
+      priorTxHash: 'landed-hash',
+      priorTxSubmittedLedger: 1,
+    });
+
+    expect(result.deduped).toBe(true);
+    expect(rpcState.calls.sendTransaction).toHaveLength(0);
+  });
+
+  it('returns submittedLedger (sim.latestLedger) on a fresh submit so the caller can persist it for a future retry', async () => {
