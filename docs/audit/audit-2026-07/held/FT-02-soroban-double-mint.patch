+describe('submitSorobanInvocation — CF-18 aged-out NOT_FOUND disambiguation (FT-02)', () => {
+  // A Soroban RPC retains tx history only for a bounded window. A
+  // deposit/withdraw that LANDED but then aged out of that window
+  // returns NOT_FOUND — identical to a tx that never landed. Treating
+  // the aged-out-but-landed case as never-landed lets a delayed retry
+  // build a fresh tx and DOUBLE-submit (double-mint / operator USDC
+  // loss). `priorTxSubmittedLedger` (the ledger the original attempt
+  // submitted at, persisted with the hash) disambiguates: a NOT_FOUND is
+  // authoritative only while the RPC's retained window still reaches
+  // back to that ledger.
+
+  it('FAILS CLOSED when the prior tx submit ledger has aged out of the RPC history — no re-submit (no double-mint)', async () => {
+    // getTransaction says NOT_FOUND, but the retained window now starts
+    // at oldestLedger=500 — PAST the ledger (100) the prior tx submitted
+    // at. So a landed-then-pruned tx is indistinguishable from
+    // never-landed; re-submitting risks a second on-chain deposit.
+    rpcState.getTransactionResults.set('aged-out-hash', {
+      status: rpc.Api.GetTransactionStatus.NOT_FOUND,
+      txHash: 'aged-out-hash',
+      oldestLedger: 500,
+      latestLedger: 800,
+    });
