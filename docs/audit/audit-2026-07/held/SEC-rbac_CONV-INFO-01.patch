--- /dev/null
+++ b/apps/backend/src/__tests__/integration/staff-role-revocation.test.ts
@@ -0,0 +1,116 @@
+/**
+ * SEC-rbac integration proof — a staff-role REVOKE must STICK for an
+ * env-allowlisted admin across their next login's re-grant.
+ *
+ * The bug: `is_admin` is recomputed from the env allowlists
+ * (`ADMIN_EMAILS` / `ADMIN_CTX_USER_IDS`) on every login —
+ * `upsertUserFromCtx` on a CTX request, `findOrCreateUserByEmail`'s
+ * config-parity reconcile on native OTP login. `revokeStaffRole` used
+ * to only delete the `staff_roles` row and clear the `is_admin` mirror,
+ * so the very next login re-set `is_admin = true` and the revoked admin
+ * silently regained access (fail-open). The fix latches a durable
+ * `users.admin_revoked` flag that the re-grant paths honor.
+ *
+ * This exercises the CTX path against real postgres (the unit suite
+ * pins the native/reconcile path with a mocked db; the SQL
+ * `env AND NOT admin_revoked` conflict expression only evaluates for
+ * real here). Gated on `LOOP_E2E_DB=1` like the sibling suites; the
+ * integration setup pins `ADMIN_CTX_USER_IDS='test-admin-id'`.
+ */
+import { describe, it, expect, beforeAll, beforeEach } from 'vitest';
+import { eq } from 'drizzle-orm';
+
+const RUN_INTEGRATION = process.env['LOOP_E2E_DB'] === '1';
+
+import { db } from '../../db/client.js';
+import { users } from '../../db/schema.js';
+import { upsertUserFromCtx, getUserById } from '../../db/users.js';
+import { grantStaffRole, revokeStaffRole, getStaffRole } from '../../db/staff-roles.js';
+import { ensureMigrated, truncateAllTables } from './db-test-setup.js';
+
+const describeIf = RUN_INTEGRATION ? describe : describe.skip;
+
+/**
+ * Keeps the last-admin invariant satisfied so revoking the env admin
+ * under test is permitted. A second, independent effective admin (a
+ * plain `is_admin=true` row) means `countEffectiveAdmins() > 1`.
+ */
+async function seedKeeperAdmin(): Promise<string> {
+  const [row] = await db
+    .insert(users)
+    .values({ email: 'keeper-admin@test.local', isAdmin: true })
+    .returning({ id: users.id });
+  if (row === undefined) throw new Error('seedKeeperAdmin: insert returned no row');
+  return row.id;
+}
+
+describeIf('SEC-rbac: env-allowlist admin revoke holds across re-login (CTX path)', () => {
+  beforeAll(async () => {
+    await ensureMigrated();
+  });
+  beforeEach(async () => {
+    await truncateAllTables();
+    await seedKeeperAdmin();
+  });
+
+  it('a revoked CTX-allowlisted admin is NOT re-granted is_admin on the next upsert', async () => {
+    // First login: env allowlist grants admin.
+    const first = await upsertUserFromCtx({ ctxUserId: 'test-admin-id', email: 'ctx-admin@test.local' });
+    expect(first.isAdmin).toBe(true);
+    expect(first.adminRevoked).toBe(false);
+
+    // Incident response: revoke the staff role.
+    const { priorRole } = await revokeStaffRole({ userId: first.id });
+    expect(priorRole).toBe('admin');
+
+    const afterRevoke = await getUserById(first.id);
+    expect(afterRevoke?.isAdmin).toBe(false);
+    expect(afterRevoke?.adminRevoked).toBe(true);
+    expect(await getStaffRole(first.id)).toBeNull();
+
+    // Next login (re-upsert). BEFORE the fix this re-set is_admin=true
+    // from env and the revoke was silently undone — the fail-open.
+    const second = await upsertUserFromCtx({ ctxUserId: 'test-admin-id', email: 'ctx-admin@test.local' });
+    expect(second.isAdmin).toBe(false);
+    expect(second.adminRevoked).toBe(true);
+
+    // And it stays revoked in the row of record.
+    const persisted = await getUserById(first.id);
+    expect(persisted?.isAdmin).toBe(false);
+  });
+
+  it('a deliberate re-grant clears the latch so a later login restores admin', async () => {
+    const first = await upsertUserFromCtx({ ctxUserId: 'test-admin-id', email: 'ctx-admin@test.local' });
+    await revokeStaffRole({ userId: first.id });
+    expect((await getUserById(first.id))?.adminRevoked).toBe(true);
+
+    // Deliberate re-grant lifts the suspension (clears admin_revoked).
+    await grantStaffRole({
+      userId: first.id,
+      role: 'admin',
+      grantedByUserId: first.id,
+      reason: 're-instated after review',
+    });
+    const afterGrant = await getUserById(first.id);
+    expect(afterGrant?.isAdmin).toBe(true);
+    expect(afterGrant?.adminRevoked).toBe(false);
+
+    // Next login now re-grants admin from env as normal (latch cleared).
+    const relogin = await upsertUserFromCtx({ ctxUserId: 'test-admin-id', email: 'ctx-admin@test.local' });
+    expect(relogin.isAdmin).toBe(true);
+  });
+
+  it('a never-revoked allowlisted admin is granted on upsert exactly as before (no regression)', async () => {
+    const row = await upsertUserFromCtx({ ctxUserId: 'test-admin-id', email: 'ctx-admin@test.local' });
+    expect(row.isAdmin).toBe(true);
+    expect(row.adminRevoked).toBe(false);
+    // Re-upsert keeps admin (latch stays false).
+    const again = await upsertUserFromCtx({ ctxUserId: 'test-admin-id', email: 'ctx-admin@test.local' });
+    expect(again.isAdmin).toBe(true);
+    // Sanity: the keeper admin is untouched.
+    const keeper = await db.query.users.findFirst({
+      where: eq(users.email, 'keeper-admin@test.local'),
+    });
+    expect(keeper?.isAdmin).toBe(true);
+  });
+});
