diff --git a/apps/backend/src/db/migrations/0064_users_admin_revoked.sql b/apps/backend/src/db/migrations/0064_users_admin_revoked.sql
new file mode 100644
index 00000000..5f3c0262
--- /dev/null
+++ b/apps/backend/src/db/migrations/0064_users_admin_revoked.sql
@@ -0,0 +1,21 @@
+-- SEC-rbac: make an incident-response staff-role REVOKE stick for an
+-- env-allowlisted admin (ADMIN_EMAILS / ADMIN_CTX_USER_IDS).
+--
+-- Before this, `revokeStaffRole` deleted the `staff_roles` row and
+-- cleared the `users.is_admin` mirror, but the env-allowlist LOGIN
+-- re-grant paths (`upsertUserFromCtx` on a CTX request,
+-- `findOrCreateUserByEmail`'s config-parity reconcile on native OTP
+-- login) recompute `is_admin` from env on the admin's very next login
+-- and flip it back to true — so revoking an allowlisted admin FAILED
+-- OPEN: they were silently re-granted admin at next login. Removing
+-- them from the env allowlist required a redeploy, which is not an
+-- incident-response timescale.
+--
+-- `admin_revoked` is a durable "this staff member was explicitly
+-- revoked" latch that the env-allowlist re-grant paths now honor: while
+-- it is true, the env allowlist can no longer resurrect `is_admin`.
+-- `grantStaffRole` clears it (a deliberate re-grant lifts the
+-- suspension), so the normal env-allowlist grant for a NON-revoked
+-- admin is unaffected. Defaults false so every existing row keeps its
+-- current env-allowlist behaviour.
+ALTER TABLE "users" ADD COLUMN "admin_revoked" boolean DEFAULT false NOT NULL;
