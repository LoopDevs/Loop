{
  "name": "loop-app",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,backend -c cyan,green \"npm run dev:web\" \"npm run dev:backend\"",
    "dev:web": "npm run dev -w @loop/web",
    "dev:backend": "npm run dev -w @loop/backend",
    "typecheck": "npm run typecheck -w @loop/backend -w @loop/web -w @loop/shared",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test -w @loop/backend -w @loop/web",
    "test:e2e": "playwright test",
    "verify": "./scripts/verify.sh",
    "lint:docs": "./scripts/lint-docs.sh",
    "build": "npm run build -w @loop/backend -w @loop/web",
    "proto:generate": "cd apps/backend && npx buf generate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@stellar/stellar-sdk": "^15.0.1",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
