# tools/ctx-catalog — media-pipeline environment (copy to a gitignored .env).
# The end-to-end flow + which stage needs which key: ./PIPELINE.md.
# Every key here is a SECRET at rest — never commit the filled-in .env.

# ── CTX admin API (read for coverage; write ONLY on an explicit --apply) ──────
# Scripts read process.env.CTX_TOKEN, falling back to /tmp/ctx-token.txt.
CTX_TOKEN=

# ── Supplier catalog APIs (stage 0 raw pull — read-only / catalog scope only) ─
# Provision READ-ONLY keys; the pull adapters only ever call catalog/brand
# endpoints, never order/redeem/balance. (Adapters land when these arrive.)
TILLO_API_KEY=
TILLO_API_SECRET=
SVS_API_KEY=
EZPIN_API_KEY=

# ── Logo + image sourcing ─────────────────────────────────────────────────────
# logo.dev publishable pk_ key (fetch-logos, review-server). Fallback:
# /tmp/logodev-key.txt. Treat as a secret even though it's the publishable tier.
LOGODEV_KEY=
TAVILY_API_KEY=

# ── Claude passes (ai-extract / ai-info / vision-qc) — plain Messages API ─────
ANTHROPIC_API_KEY=
# Optional model overrides (default: claude-sonnet-5):
# AI_EXTRACT_MODEL=claude-sonnet-5
# AI_INFO_MODEL=claude-sonnet-5
# AI_VISION_MODEL=claude-sonnet-5

# ── Durable state dir (default: this tool's git-tracked data/) ────────────────
# CTX_DATA_DIR=/absolute/path      # override where the ledger/manifests live
# CTX_CACHE_DIR=/tmp               # throwaway image-proxy cache
