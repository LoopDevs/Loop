# Loop Web — Local Development Environment
# Copy to .env.local and adjust as needed. Never commit .env.local.
# .env.production (committed) sets production values — no secrets allowed there.

# URL of the running backend API
VITE_API_URL=http://localhost:8080

# FE-22: Phase-1 launch gate SSR/first-paint default. Set to match your
# backend's LOOP_PHASE_1_ONLY so the gate a crawler sees (SSR HTML) equals
# what the runtime hydrates to. Unset → `true` (Phase-1, gated). Set to
# `false` to exercise the Phase-2 surfaces (cashback/wallet/trustlines)
# locally without waiting on /api/config.
# VITE_PHASE_1_ONLY=false

# Error tracking (optional — get DSN from sentry.io)
# VITE_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
# A2-1310: logical-env tag for Sentry (paired with LOOP_ENV on
# backend). Set to `staging` on staging builds so Sentry buckets
# staging events away from production. Unset → falls back to
# `import.meta.env.MODE`.
# VITE_LOOP_ENV=staging
# A2-1309: release tag for Sentry (paired with SENTRY_RELEASE on
# backend). CI/CD sets this to the git SHA at build time so Sentry
# can pivot from an event to the exact web bundle. Absent → Sentry
# omits `release`.
# VITE_SENTRY_RELEASE=<git-sha or v1.2.3+<sha>>

# ADR 048: first-party, cookieless Core Web Vitals + page-view capture.
# 'true' dynamically imports `web-vitals` and POSTs observations to
# POST /api/public/rum (folded into /metrics — no DB, no PII, no
# persistent id). Default unset/off.
# VITE_ANALYTICS_ENABLED=true
