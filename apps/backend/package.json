    "@loop/shared": "*",
    "@sentry/hono": "^10.48.0",
    "hono": "^4.12.12",
    "pino": "^10.3.1",
    "sharp": "^0.34.5",
    "zod": "^4.1.3"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.67.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.4",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "*",
    "vitest": "^4.1.0"
  }
