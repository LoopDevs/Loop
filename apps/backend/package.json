{
  "name": "@loop/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "LOOP_E2E_DB=1 vitest run --config=vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "check:ledger": "tsx src/scripts/check-ledger-invariant.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "8.5.0",
    "@bufbuild/protobuf": "2.12.0",
    "@hono/node-server": "2.0.1",
    "@loop/shared": "*",
    "@sentry/hono": "10.51.0",
    "@stellar/stellar-sdk": "15.0.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.16",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "sharp": "0.34.5",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.69.0",
    "@bufbuild/protoc-gen-es": "2.12.0",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
