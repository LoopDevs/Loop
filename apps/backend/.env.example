# Loop Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# Server
PORT=8080
NODE_ENV=development         # development | production
LOG_LEVEL=info               # debug | info | warn | error

# Gift Card API (required — obtain from provider)
GIFT_CARD_API_BASE_URL=https://api.example.com
GIFT_CARD_API_KEY=your_api_key_here
GIFT_CARD_API_SECRET=your_api_secret_here

# JWT secrets (required — generate with Node.js crypto)
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_secret

# Email (required for OTP delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@loopfinance.io

# Cache refresh intervals (optional — defaults shown)
REFRESH_INTERVAL_HOURS=6            # merchant catalog refresh
LOCATION_REFRESH_INTERVAL_HOURS=24  # location data refresh

# Image proxy security — recommended in production
# Comma-separated allowed hostnames. If set, only these hosts are fetched (SSRF prevention).
# Example: IMAGE_PROXY_ALLOWED_HOSTS=cdn.giftcards.com,images.merchant.com
# IMAGE_PROXY_ALLOWED_HOSTS=
