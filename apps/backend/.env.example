# Loop Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Upstream Gift Card API
GIFT_CARD_API_BASE_URL=https://spend.ctx.com

# Optional: API credentials for endpoints that require auth (e.g. /locations)
# GIFT_CARD_API_KEY=your_api_key_here
# GIFT_CARD_API_SECRET=your_api_secret_here

# CTX client IDs for auth — one per platform (defaults shown)
# CTX_CLIENT_ID_WEB=loopweb
# CTX_CLIENT_ID_IOS=loopios
# CTX_CLIENT_ID_ANDROID=loopandroid

# Dev mode: include disabled merchants so UI can be tested
# INCLUDE_DISABLED_MERCHANTS=true

# A2-1922: comma-separated CTX merchant IDs filtered out of the
# catalog at sync time. Loop's deny-list for merchants we refuse to
# resell — slurs in brand name, upstream entries hidden during a
# dispute, commercial relationships not yet agreed. Filter applies
# before in-memory store so denied IDs never reach the public API or
# admin catalog. Empty / absent → no filter.
# LOOP_MERCHANT_DENYLIST=merchant-id-1,merchant-id-2

# Cache refresh intervals (optional — defaults shown)
REFRESH_INTERVAL_HOURS=6
LOCATION_REFRESH_INTERVAL_HOURS=24

# Image proxy security — REQUIRED in production (audit A-025).
# Comma-separated upstream image hostnames. Only URLs hosted on one of
# these hosts will be fetched by the image proxy; anything else gets
# 403'd before any network call (SSRF + DNS-rebinding mitigation).
# Boot fails in production if this isn't set. Dev/test: optional.
# IMAGE_PROXY_ALLOWED_HOSTS=spend.ctx.com,ctx-spend.s3.us-west-2.amazonaws.com
#
# Emergency override (production only, do not use casually):
# DISABLE_IMAGE_PROXY_ALLOWLIST_ENFORCEMENT=1

# Rate limiter trust boundary (audit A-023). Set to `true` only when
# running behind a trusted edge proxy (Fly.io, nginx, Cloudflare, etc.)
# that rewrites X-Forwarded-For. Otherwise leave unset — the rate
# limiter falls back to the TCP socket IP, which a client cannot spoof.
# Default: false.
# TRUST_PROXY=true

# Rate-limit escape hatch for e2e test harnesses (#658). Set to `1`
# ONLY in test configs (playwright.mocked.config.ts, etc.). When
# set, every per-IP limit on every route is bypassed — production
# must never enable this.
# DISABLE_RATE_LIMITING=1

# A2-1610: per-admin per-currency daily cap on credit adjustments
# (minor units). Guards against a stolen admin session draining the
# treasury via many sub-per-request-cap writes inside the token TTL.
# Default 100_000_000 (£1M / $1M / €1M) — a volume in-flight ops
# would never hit in a single UTC day. Set to `0` to disable (dev
# / test). The per-request ±10M cap is separate and always on.
# ADMIN_DAILY_ADJUSTMENT_CAP_MINOR=100000000

# A2-1606 / A2-1607: shared-secret bearer tokens for /metrics and
# /openapi.json. When set, requests must carry
# `Authorization: Bearer <token>`. Unset in development / test leaves
# those routes open (local tooling + vitest); unset in production
# makes them 404 so an anonymous probe can't fingerprint us. Minimum
# 16 chars — typical Prometheus scraper token is 32+.
# METRICS_BEARER_TOKEN=<32+ random chars>
# OPENAPI_BEARER_TOKEN=<32+ random chars>

# Discord webhooks (optional — for notifications)
# DISCORD_WEBHOOK_ORDERS=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_MONITORING=https://discord.com/api/webhooks/...
# ADR 017 / 018 admin-write audit fanout. Fire-and-forget AFTER DB
# commit of every admin mutation. Leave unset in dev; set in prod.
# DISCORD_WEBHOOK_ADMIN_AUDIT=https://discord.com/api/webhooks/...

# Error tracking (optional — get DSN from sentry.io)
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
# A2-1310: logical-env tag for Sentry (paired with VITE_LOOP_ENV on
# web). Set to `staging` on staging deploys that run NODE_ENV=production
# so Sentry bucketing matches between backend and web. Unset → falls
# back to NODE_ENV.
# LOOP_ENV=staging
# A2-1309: release tag for Sentry (paired with VITE_SENTRY_RELEASE on
# web). CI/CD sets this to the git SHA (or version+SHA) so Sentry
# can pivot from an event to the exact deploy artifact. Absent →
# Sentry omits `release` on every event (pre-launch default).
# SENTRY_RELEASE=<git-sha or v1.2.3+<sha>>

# Database (ADR 012). Required. `docker compose up -d db` brings up a
# local Postgres on :5433 matching the default below.
DATABASE_URL=postgres://loop:loop@localhost:5433/loop
# Pool size per Node process. Tune if a machine hosts more workers.
# DATABASE_POOL_MAX=10

# A2-724: per-session statement_timeout (milliseconds). Sent as a
# startup parameter on every connection so a runaway query can't
# monopolise a pool slot. 30s baseline is well above every
# documented admin endpoint with current indexes (A2-708/709/716);
# 0 disables. Heavy backfill migrations would need a per-migration
# override (`SET LOCAL statement_timeout = 0` at the top of the SQL).
# DATABASE_STATEMENT_TIMEOUT_MS=30000

# Admin panel (ADR 011). Comma-separated list of CTX user IDs (the
# `sub` claim of the user's bearer token) granted admin privileges.
# Match on CTX sub (not email) so the upsert path stays synchronous
# with the JWT — no round-trip to CTX /me on every admin request.
# Leave empty to disable admin endpoints entirely.
# ADMIN_CTX_USER_IDS=abc-123-xyz,def-456-uvw

# Defaults for the cashback split applied to newly-synced merchants
# that don't yet have an admin-set merchant_cashback_configs row
# (ADR 011). Expressed as percent-of-face-value (e.g. "8.00" = 8%).
# The sum must be ≤ 100 — wholesale is residual. Default 0/0 means a
# new merchant earns zero cashback until ops configures them.
# DEFAULT_USER_CASHBACK_PCT_OF_CTX=0.00
# DEFAULT_LOOP_MARGIN_PCT_OF_CTX=0.00

# Loop-signed JWT secret (ADR 013). Used to sign + verify
# Loop-issued access and refresh tokens. Absent → Loop-native auth
# is disabled and the legacy CTX-proxy auth path is the only route.
# Minimum 32 chars of entropy; rotate by moving the old value to
# LOOP_JWT_SIGNING_KEY_PREVIOUS for the access-token TTL, then drop
# it. Generate a fresh secret with `openssl rand -base64 48`.
# LOOP_JWT_SIGNING_KEY=<at-least-32-char-random-secret>
# LOOP_JWT_SIGNING_KEY_PREVIOUS=<prior-secret-during-rotation-only>

# Loop-native auth feature flag (ADR 013). When true, /request-otp
# (and, as they ship, /verify-otp + /refresh) take the Loop-native
# path: Loop sends the OTP email and mints its own JWTs. Default
# false → the legacy CTX-proxy auth path stays in place.
# LOOP_AUTH_NATIVE_ENABLED=false

# Social login — Google (ADR 014). One OAuth client id per platform.
# At least one must be set for /api/auth/social/google to be live;
# the id_token's `aud` must match one of these. Create in Google
# Cloud Console → APIs & Services → Credentials.
# GOOGLE_OAUTH_CLIENT_ID_WEB=<web-client>.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_ID_IOS=<ios-client>.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_ID_ANDROID=<android-client>.apps.googleusercontent.com

# Social login — Apple (ADR 014). The Sign in with Apple service id
# (web) or bundle id (native). Apple's id_token `aud` must match.
# Absent → /api/auth/social/apple returns 404.
# APPLE_SIGN_IN_SERVICE_ID=io.loopfinance.app

# CTX operator-account pool (ADR 013). JSON array of service accounts
# Loop uses to talk to CTX once the identity takeover is live. Each
# entry is `{ "id": "<human name>", "bearer": "<ctx-jwt>" }`. At least
# 2 entries are recommended in production — a single operator account
# is a single point of failure for rate-limits, lockouts, and key
# rotation (ADR 013 for the full reasoning). Absent → pool is inert
# and any call through it returns 503; safe while the principal
# switch (ADR 010) hasn't wired it in yet.
# CTX_OPERATOR_POOL=[{"id":"primary","bearer":"eyJ..."},{"id":"backup-1","bearer":"eyJ..."}]

# Loop's Stellar deposit address for Loop-native orders (ADR 010).
# Users paying with XLM / USDC send to this address, encoding the
# order's payment memo in the transaction's memo_text. The payment
# watcher polls Horizon and transitions matching orders to `paid`.
# Absent → /api/orders/loop returns 503 for xlm / usdc methods;
# credit-funded orders still work.
# LOOP_STELLAR_DEPOSIT_ADDRESS=GA7QYNF7SOWQ3GLR2BGMZEHXAVIRZA4KVWLTJJFC7MGXUA74P7UJVSGV

# Stellar Horizon URL the payment watcher polls. Defaults to public
# Mainnet; set to `https://horizon-testnet.stellar.org` for staging.
# Not validated by env.ts — the horizon client reads process.env
# directly so test suites can flip it without a module reload.
# LOOP_STELLAR_HORIZON_URL=https://horizon.stellar.org

# XLM price oracle URL. Response shape must match CoinGecko's
# /simple/price: { stellar: { usd: number, gbp?: number, eur?: number } }.
# Default is the public CoinGecko endpoint; operators override with
# a self-hosted / paid feed via this var. The watcher caches 60s.
# LOOP_XLM_PRICE_FEED_URL=https://api.coingecko.com/api/v3/simple/price?ids=stellar&vs_currencies=usd,gbp,eur

# Fiat FX feed URL for USDC-against-non-USD orders. Response shape
# must match Frankfurter: { base: "USD", rates: { GBP: number, EUR: number } }.
# Default is the public Frankfurter endpoint (ECB-sourced, no key);
# operators override with a self-hosted / paid feed. 60s cache.
# LOOP_FX_FEED_URL=https://api.frankfurter.app/latest?from=USD&to=GBP,EUR

# USDC issuer account the watcher pins as an asset-match guard.
# Centre on mainnet is GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN.
# Absent → watcher accepts USDC from any issuer (MVP leniency).
# LOOP_STELLAR_USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# Issuer accounts for the three LOOP-branded Stellar assets (ADR 015).
# Loop issues USDLOOP / GBPLOOP / EURLOOP 1:1-backed against fiat
# reserves; cashback is paid to the user in the asset matching their
# home currency. Absent → payout worker skips the Stellar-side
# transfer for that currency and accrues cashback off-chain only.
# Without these set, the watcher also refuses to allowlist the
# matching LOOP asset as an inbound user payment (prevents a spoofed
# "USDLOOP" from an unrelated issuer being accepted).
# LOOP_STELLAR_USDLOOP_ISSUER=
# LOOP_STELLAR_GBPLOOP_ISSUER=
# LOOP_STELLAR_EURLOOP_ISSUER=

# Procurement USDC-reserve floor (ADR 015). When our operator USDC
# balance drops below this many stroops (7 decimals; 10^7 = 1 USDC),
# procurement pays CTX in XLM instead so fulfillment doesn't stall
# while the USDC top-up is in flight. Absent → fallback disabled,
# procurement always uses USDC. Below-floor events get ops-flagged
# in admin/treasury.
# Example: 1_000_000_000 stroops = 100 USDC minimum reserve.
# LOOP_STELLAR_USDC_FLOOR_STROOPS=1000000000

# Operator Stellar secret for outbound cashback payouts (ADR 016).
# Signs LOOP-asset Payments to users' linked wallets. Never log,
# never surface via API; pino redaction paths are set at
# `secret`, `operatorSecret`, and both env names. Absent →
# payout worker is inert and pending_payouts rows queue until
# ops plumbs this.
# Rotation: move the active key to _PREVIOUS for the access-token
# TTL, deploy with both set, then drop the old. Mirrors the JWT
# signing-key rotation pattern.
# LOOP_STELLAR_OPERATOR_SECRET=SXXXXX...
# LOOP_STELLAR_OPERATOR_SECRET_PREVIOUS=SYYYYY...

# Network passphrase for payout signing (ADR 016). PUBLIC mainnet
# is the default; set to "Test SDF Network ; September 2015" for
# testnet. Self-hosted networks set their own passphrase.
# LOOP_STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# Payout-worker tick interval (seconds, ADR 016). 30s matches the
# pacing guidance — slower than the watcher/procurement because
# each Stellar submit + ledger close runs ~5s and sequence numbers
# serialise on the operator account.
# LOOP_PAYOUT_WORKER_INTERVAL_SECONDS=30

# Max transient-failure retries before a payout row promotes to
# terminal `failed` (ops intervention via admin retry). ADR 016
# default 5.
# LOOP_PAYOUT_MAX_ATTEMPTS=5

# A2-602 watchdog: rows stuck in `submitted` past this (seconds) are
# re-picked by the worker. Prevents rows from stalling forever if the
# pod dies between submit and confirm, or the mark-confirmed DB write
# fails. Idempotency pre-check converges already-landed payments to
# `confirmed`; otherwise a fresh submit is issued with new sequence.
# Default 300s (5m) — well above the normal submit→seal window (~5s).
# LOOP_PAYOUT_WATCHDOG_STALE_SECONDS=300

# A2-1921 fee-bump strategy. The submit worker scales the Stellar
# transaction fee per attempt so a congested network drains naturally
# instead of going terminal at base fee:
#   attempt 1 → BASE
#   attempt 2 → BASE * MULTIPLIER
#   attempt N → BASE * MULTIPLIER^(N-1)  (capped at CAP)
# Defaults: 100 → 200 → 400 → 800 → 1600 stroops at MULTIPLIER=2,
# CAP=100_000 (any fee under the cap is well below $0.001 even on
# mainnet — cheap insurance against a stuck row).
# LOOP_PAYOUT_FEE_BASE_STROOPS=100
# LOOP_PAYOUT_FEE_CAP_STROOPS=100000
# LOOP_PAYOUT_FEE_MULTIPLIER=2

# Loop-native order workers (ADR 010). When true, the backend starts
# the payment watcher (polls Horizon for deposits → transitions orders
# to `paid`) and procurement worker (calls CTX via operator pool →
# transitions `paid` → `fulfilled`). Default false.
# LOOP_WORKERS_ENABLED=false

# A2-1907: runtime kill switches. Set any to `true` and the matching
# surface returns 503 SUBSYSTEM_DISABLED on the next request — no
# redeploy. Operator runbook at docs/runbooks/kill-switch.md.
# - ORDERS gates POST /api/orders + /api/orders/loop
# - AUTH gates request-otp + verify-otp + social/google + social/apple
#   (refresh + logout intentionally remain open so existing sessions can
#   drain on next refresh)
# - WITHDRAWALS gates the admin withdrawal + compensation endpoints
# LOOP_KILL_ORDERS=false
# LOOP_KILL_AUTH=false
# LOOP_KILL_WITHDRAWALS=false

# Tick intervals for the workers, in seconds. Defaults: 10s watcher /
# 5s procurement.
# LOOP_PAYMENT_WATCHER_INTERVAL_SECONDS=10
# LOOP_PROCUREMENT_INTERVAL_SECONDS=5

# Asset-drift watcher (ADR 015). Polls Horizon for each configured
# LOOP asset, compares against the off-chain ledger liability, and
# pages the monitoring Discord channel when |drift| exceeds the
# threshold. 300s tick matches accounting cadence — drift is not
# latency-sensitive. Threshold in stroops: 1e8 = 10 whole LOOP units
# (=$10 for USDLOOP) — covers normal in-flight payout drift while
# catching accounting divergence.
# LOOP_ASSET_DRIFT_WATCHER_INTERVAL_SECONDS=300
# LOOP_ASSET_DRIFT_THRESHOLD_STROOPS=100000000

# A2-905 / ADR 009: interest accrual scheduler. Off by default
# (0 bps) — ADR 009 gates this behind legal sign-off per target
# market. Set to a positive integer-basis-points value to enable
# (400 = 4.00% APY). Scheduler runs under LOOP_WORKERS_ENABLED.
# Per-year period denominator: 365 daily, 12 monthly, 52 weekly.
# Tick interval in hours — kept independent from periodsPerYear so
# restart-safety leans on the per-cursor DB unique index rather
# than the schedule cadence.
# INTEREST_APY_BASIS_POINTS=0
# INTEREST_PERIODS_PER_YEAR=365
# INTEREST_TICK_INTERVAL_HOURS=24
