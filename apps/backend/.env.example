# Loop Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# Server
PORT=8080
NODE_ENV=development         # development | production
LOG_LEVEL=info               # debug | info | warn | error

# Upstream Gift Card API (public — no auth needed)
GIFT_CARD_API_BASE_URL=https://spend.ctx.com

# Cache refresh intervals (optional — defaults shown)
REFRESH_INTERVAL_HOURS=6            # merchant catalog refresh
LOCATION_REFRESH_INTERVAL_HOURS=24  # location data refresh

# Image proxy security — recommended in production
# Comma-separated allowed hostnames. If set, only these hosts are fetched (SSRF prevention).
# Example: IMAGE_PROXY_ALLOWED_HOSTS=cdn.giftcards.com,images.merchant.com
# IMAGE_PROXY_ALLOWED_HOSTS=
