# Loop Android release-signing config — operator-only.
#
# Copy this file to `apps/mobile/android/keystore.properties` and fill
# in the real values. The destination path is gitignored (cap add
# android's .gitignore covers it via `local.properties`-style
# exclusion); do NOT check the real file in. The .keystore file itself
# also stays out of the repo — back it up to a secure location (1Password,
# offline storage). Losing the keystore means losing the ability to ship
# updates to the same Play Store package — a permanent loss of identity.
#
# Generation:
#
#   keytool -genkeypair -v \
#     -keystore loop-release.keystore \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias loop
#
# After answering the prompts, drop loop-release.keystore into
# apps/mobile/android/ and the path below resolves correctly.
# Alternatively use an absolute path to keep the keystore out of the
# repo entirely.

storeFile=loop-release.keystore
storePassword=CHANGE_ME
keyAlias=loop
keyPassword=CHANGE_ME
