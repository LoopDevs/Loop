<?xml version="1.0" encoding="utf-8"?>
<!--
    Audit A-033: pre-Android-12 auto-backup exclusion for sensitive
    purchase / session state. The web layer stores pending-order state
    via the Capacitor Preferences plugin, backed by SharedPreferences
    under the default name "CapacitorStorage". Without this rules file
    that preferences file would be swept into Google Drive / ADB
    full-backup channels and restored onto any device the user signs
    in on. Refresh tokens and email live in
    EncryptedSharedPreferences via @aparajita/capacitor-secure-storage
    (audit A-024, ADR-006) — they are Keystore-bound, so ciphertext
    swept by a backup cannot be decrypted on a different device, but
    we still exclude any pre-A-024 Preferences residue here for
    defense in depth.

    Applied to the generated `apps/mobile/android/` project by
    `apps/mobile/scripts/apply-native-overlays.sh` after `npx cap add`
    / `npx cap sync`. `apps/mobile/android/` is gitignored (audit A-012)
    so this overlay file is the canonical source of truth.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="CapacitorStorage.xml" />
</full-backup-content>
