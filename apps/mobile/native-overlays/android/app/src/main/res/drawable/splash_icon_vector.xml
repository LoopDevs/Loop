<!--
  Loop wordmark VectorDrawable. Paths transcribed from
  apps/web/public/loop-logo.svg (viewBox 172.22 x 71). Each letter lives
  in its own named group + named path so AVD variants can animate them
  individually (fillAlpha on paths, translate/scale on groups). The
  outer `mark` group covers whole-word animations; the inner scaler
  positions the wordmark inside the 72dp safe zone of the 108dp canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:name="mark"
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="1"
        android:scaleY="1">
        <group
            android:translateX="21.6"
            android:translateY="40.65"
            android:scaleX="0.376"
            android:scaleY="0.376">
            <!-- Each letter group sets pivotX to its own left edge so a
                 scaleX animation reveals the letter from the left. pivotY
                 sits roughly at vertical centre of the wordmark. scaleX/Y
                 are declared so objectAnimator has a property to attach
                 to; initial value is 1 so static renders stay correct. -->
            <!-- Each letter group has a clip-path rectangle sized to
                 its bounding box. The wipe/draw AVD animates each
                 clip-path's pathData from a zero-width rect at the
                 letter's left edge out to the full rect — revealing
                 the letter left-to-right with no shape distortion. -->
            <group
                android:name="letter_l_g"
                android:pivotX="0"
                android:pivotY="26"
                android:scaleX="1"
                android:scaleY="1">
                <clip-path
                    android:name="letter_l_clip"
                    android:pathData="M-16,26 C-16,8.8787 -2.1213,-5 15,-5 C32.1213,-5 46,8.8787 46,26 C46,43.1213 32.1213,57 15,57 C-2.1213,57 -16,43.1213 -16,26 Z"/>
                <path
                    android:name="letter_l_p"
                    android:fillColor="#FFFFFF"
                    android:fillAlpha="1"
                    android:pathData="M0,52V0h10v43h20v9H0Z"/>
            </group>
