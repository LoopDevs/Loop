                android:startOffset="200"/>
        </aapt:attr>
    </target>
    <!-- P -->
    <target android:name="letter_p_clip">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="pathData"
                android:valueFrom="M149,39.5 C149,38.9477 149.448,38.5 150,38.5 C150.552,38.5 151,38.9477 151,39.5 C151,40.0523 150.552,40.5 150,40.5 C149.448,40.5 149,40.0523 149,39.5 Z"
                android:valueTo="M110,39.5 C110,17.408 127.908,-0.5 150,-0.5 C172.092,-0.5 190,17.408 190,39.5 C190,61.592 172.092,79.5 150,79.5 C127.908,79.5 110,61.592 110,39.5 Z"
                android:valueType="pathType"
                android:duration="500"
                android:startOffset="300"
                android:interpolator="@android:interpolator/decelerate_cubic"/>
        </aapt:attr>
    </target>
    <target android:name="letter_p_p">
