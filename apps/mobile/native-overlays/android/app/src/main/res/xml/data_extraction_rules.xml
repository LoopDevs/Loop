<?xml version="1.0" encoding="utf-8"?>
<!--
    Audit A-033: Android 12+ split auto-backup into `cloud-backup`
    (Google Drive) and `device-transfer` (setup-time device-to-device).
    Exclude the Capacitor Preferences file from both — refresh tokens
    and pending-order state stay on the device where they were issued.

    Paired with `backup_rules.xml` which covers pre-Android-12 devices
    via `fullBackupContent`.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="CapacitorStorage.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="CapacitorStorage.xml" />
    </device-transfer>
</data-extraction-rules>
