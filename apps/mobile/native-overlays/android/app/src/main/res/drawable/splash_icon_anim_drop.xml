<!--
  Variant E: staggered letter drop-in. Each letter falls from ~15
  units above (in the wordmark's 172x71 coord space — scaled by 0.376
  by the parent group, so roughly 5.6 canvas units) and fades in.
  Staggered 150ms so the wordmark appears to drop in L → O → O → P.
  Decelerate_cubic on translate gives a soft landing. Total ~850ms,
  inside the 1000ms splash cap.
-->
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/splash_icon_vector">
    <!-- L -->
    <target android:name="letter_l_g">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="-15"
                android:valueTo="0"
                android:duration="400"
                android:startOffset="0"
                android:interpolator="@android:interpolator/decelerate_cubic"/>
        </aapt:attr>
    </target>
    <target android:name="letter_l_p">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="400"
                android:startOffset="0"/>
        </aapt:attr>
    </target>
    <!-- O1 -->
    <target android:name="letter_o1_g">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="-15"
                android:valueTo="0"
                android:duration="400"
                android:startOffset="150"
                android:interpolator="@android:interpolator/decelerate_cubic"/>
        </aapt:attr>
    </target>
    <target android:name="letter_o1_p">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="400"
                android:startOffset="150"/>
        </aapt:attr>
    </target>
    <!-- O2 -->
    <target android:name="letter_o2_g">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="-15"
                android:valueTo="0"
                android:duration="400"
                android:startOffset="300"
                android:interpolator="@android:interpolator/decelerate_cubic"/>
        </aapt:attr>
    </target>
    <target android:name="letter_o2_p">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="400"
                android:startOffset="300"/>
        </aapt:attr>
    </target>
    <!-- P -->
    <target android:name="letter_p_g">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="-15"
                android:valueTo="0"
                android:duration="400"
                android:startOffset="450"
                android:interpolator="@android:interpolator/decelerate_cubic"/>
        </aapt:attr>
    </target>
    <target android:name="letter_p_p">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="400"
                android:startOffset="450"/>
        </aapt:attr>
    </target>
</animated-vector>
