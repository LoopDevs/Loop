<!--
  Variant C: staggered letter slide-up + fade. Each letter rises from
  ~15 units below (in the 172x71 wordmark space, inside the 0.376
  scaled parent group — so ~5.6 canvas units, a soft lift) and fades
  in, offset 100ms apart. translateY animates the group, fillAlpha
  animates the path inside — one target per property per letter.
-->
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/splash_icon_vector">
    <!-- L -->
    <target android:name="letter_l_g">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="15"
                android:valueTo="0"
                android:duration="400"
                android:startOffset="0"
                android:interpolator="@android:interpolator/decelerate_quint"/>
        </aapt:attr>
    </target>
    <target android:name="letter_l_p">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="400"
                android:startOffset="0"/>
        </aapt:attr>
    </target>
    <!-- O1 -->
    <target android:name="letter_o1_g">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="15"
                android:valueTo="0"
                android:duration="400"
                android:startOffset="100"
                android:interpolator="@android:interpolator/decelerate_quint"/>
        </aapt:attr>
    </target>
    <target android:name="letter_o1_p">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="400"
                android:startOffset="100"/>
        </aapt:attr>
    </target>
    <!-- O2 -->
    <target android:name="letter_o2_g">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="15"
                android:valueTo="0"
                android:duration="400"
                android:startOffset="200"
                android:interpolator="@android:interpolator/decelerate_quint"/>
        </aapt:attr>
    </target>
    <target android:name="letter_o2_p">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="400"
                android:startOffset="200"/>
        </aapt:attr>
    </target>
    <!-- P -->
    <target android:name="letter_p_g">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:valueFrom="15"
                android:valueTo="0"
                android:duration="400"
                android:startOffset="300"
                android:interpolator="@android:interpolator/decelerate_quint"/>
        </aapt:attr>
    </target>
    <target android:name="letter_p_p">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="400"
                android:startOffset="300"/>
        </aapt:attr>
    </target>
</animated-vector>
