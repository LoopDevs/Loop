# Enforce branch naming convention
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "main" ] && ! echo "$BRANCH" | grep -qE "^(feat|fix|chore|docs|test|refactor|perf|ci|build)/"; then
  echo "ERROR: Branch name '$BRANCH' doesn't match convention."
  echo "Use: feat/, fix/, chore/, docs/, test/, refactor/, perf/, ci/, build/"
  exit 1
fi

# A2-411: run the full local verification suite — typecheck, lint,
# format:check, lint-docs, tests — so a push that would fail CI's
# Quality job fails locally instead. Previously pre-push only ran
# `npm test` + `lint-docs.sh`, leaving typecheck / lint / format drift
# to surface only after the CI cycle started.
./scripts/verify.sh
